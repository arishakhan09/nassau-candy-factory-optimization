# ─────────────────────────────────────────────────────────────────────────────
# Nassau Candy Factory Optimization — .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# Python bytecode / cache
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/
*.pyc

# Virtual environments
venv/
.venv/
env/
.env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Jupyter
.ipynb_checkpoints/

# Streamlit
.streamlit/

# ─────────────────────────────────────────────────────────────────────────────
# Trained model artifacts (exceed GitHub 100 MB limit — reproducible via script)
# ─────────────────────────────────────────────────────────────────────────────
models/*.joblib
models/*.pkl

# ─────────────────────────────────────────────────────────────────────────────
# Generated reports & figures (reproducible on demand)
# ─────────────────────────────────────────────────────────────────────────────
*.docx
_report_figures/
generate_report.py
generate_executive_summary.py

# Parquet (large simulation outputs)
data/outputs/simulations/*.parquet

# Microsoft Office temp/lock files
~$*.docx
~$*.xlsx
~$*.pptx
*.tmp
